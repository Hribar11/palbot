# Create a bot at https://discord.com/developers/applications and paste its token here.
DISCORD_TOKEN=[CHANGEME]

# Optional, but recommended: your Discord server ID. Commands sync immediately to this server.
DISCORD_GUILD_ID=[CHANGEME]

# Role names are case-sensitive. Admins can also use every player command.
PALWORLD_PLAYER_ROLE_NAME=Palworld Players
PALWORLD_ADMIN_ROLE_NAME=Palworld Admins

# Full path to the top-level dedicated server launcher.
PALSERVER_EXE=C:\PalworldServer\PalServer.exe

# Palworld installation directory containing PalServer.exe.
PALSERVER_WORKING_DIR=C:\PalworldServer

# Active configuration file edited by the admin-only /palconfig commands.
PALWORLD_SETTINGS_INI=C:\PalworldServer\Pal\Saved\Config\WindowsServer\PalWorldSettings.ini

# Arguments passed to the server. Leave empty if none are needed.
PALSERVER_ARGS=-useperfthreads -NoAsyncLoadingThread -UseMultithreadForDS

# Seconds to wait for graceful termination before force-killing the process tree.
STOP_TIMEOUT_SECONDS=30

# Palworld's local REST API. Keep this bound to localhost/LAN; never expose it publicly.
PAL_REST_API_URL=http://127.0.0.1:8212/v1/api
PAL_REST_API_USER=admin

# This must match AdminPassword in PalWorldSettings.ini.
PAL_REST_API_PASSWORD=replace-with-palworld-admin-password

# Players see this warning before a graceful shutdown.
SHUTDOWN_DELAY_SECONDS=10
SHUTDOWN_MESSAGE=Server is shutting down for maintenance.

# JSON-lines audit log for every slash-command invocation. Rotates at 5 MiB by default.
COMMAND_LOG_FILE=C:\PalBot\logs\commands.log
COMMAND_LOG_MAX_BYTES=5242880
COMMAND_LOG_BACKUPS=5
